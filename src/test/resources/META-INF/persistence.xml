<?xml version="1.0" encoding="UTF-8"?>
<!--
  テスト classpath 上の persistence.xml.
  JPA 仕様上、persistence-unit を {@code Persistence.createEntityManagerFactory(...)} で
  ブートストラップするには {@code META-INF/persistence.xml} に存在する必要があるため、
  本番 {@code src/main/resources/META-INF/persistence.xml} を test classpath で上書きする。
  本番の {@code appPU} (JTA) は WildFly 経由でのみ使うため、テスト側ではここで
  {@code appTestPU} (RESOURCE_LOCAL + H2) のみを宣言する。
-->
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">
  <persistence-unit name="appTestPU" transaction-type="RESOURCE_LOCAL">
    <class>jp.mufg.it.rcb.adapter.out.persistence.TaskEntity</class>
    <exclude-unlisted-classes>true</exclude-unlisted-classes>
    <properties>
      <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
      <property name="jakarta.persistence.jdbc.url"
                value="jdbc:h2:mem:app-it;MODE=PostgreSQL;DB_CLOSE_DELAY=-1"/>
      <property name="jakarta.persistence.jdbc.user" value="sa"/>
      <property name="jakarta.persistence.jdbc.password" value=""/>
      <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>
      <property name="hibernate.hbm2ddl.auto" value="none"/>
      <property name="hibernate.show_sql" value="false"/>
    </properties>
  </persistence-unit>
</persistence>
