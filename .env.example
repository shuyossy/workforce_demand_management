# Database（docker compose の postgres コンテナをホスト 5432 にマッピング想定）
DB_URL=jdbc:postgresql://localhost:5432/rcb
DB_USER=rcb
DB_PASSWORD=rcb

# WildFly 起動モード：
#   WILDFLY_HOME を未設定/空 にすると Docker Compose で WildFly + PostgreSQL を起動（既定）。
#   WILDFLY_HOME にローカル WildFly のパスを指定すると、そのインスタンスを利用して起動する。
#     初回起動時に scripts/wildfly-local-setup.sh が admin/admin の管理ユーザと
#     PostgreSQL JDBC モジュールを冪等に整備し、standalone.sh を nohup で background 起動する
#     （-b 0.0.0.0 -bmanagement 0.0.0.0 --debug *:${WILDFLY_DEBUG_PORT}）。
#     PID / ログは .dev-runtime/ 配下。
# WILDFLY_HOME=/opt/wildfly-32.0.1.Final

# WildFly 接続情報（Docker Compose では admin/admin がコンテナに焼き込み済。
# ローカル WildFly モードでは wildfly-local-setup.sh が同じ値で add-user する）
WILDFLY_HOST=localhost
WILDFLY_MGMT_PORT=9990
WILDFLY_DEBUG_PORT=8787
WILDFLY_USER=admin
WILDFLY_PASSWORD=admin

# Application
# APP_CONTEXT_ROOT は WAR 内に置けないインフラ値（jboss-web.xml / wildfly CLI / docker-compose が参照）。
APP_CONTEXT_ROOT=/rcb
# app.* アプリ設定は src/main/resources/META-INF/microprofile-config.properties が正本。
# デプロイ固有の上書きが必要な場合のみ、対応する APP_* 環境変数をここで設定する
# （SmallRye が ordinal 300 で properties(100) を上書きする。既定値は事前宣言しない）。

# E2E
# 末尾 / が無いと Playwright の URL 解決で `/rcb` がコンテキストパスとして扱われないので必須。
BASE_URL=http://localhost:8080/rcb/

# E2E プロファイル (-Pe2e) 用 H2 接続情報。
# Maven Flyway plugin（別 JVM）と WildFly（別 JVM）の両方から同じ H2 ファイルを
# 参照するため、AUTO_SERVER=TRUE を付ける。target/h2/ 配下に置くため `mvn clean` で
# 必ず削除される（永続化目的ではない）。
H2_FILE_PATH=./target/h2/leave-e2e
# E2E プロファイル時はこの URL を DB_URL として上書き利用する（pom.xml の e2e profile 内で設定）。
# DB_URL=jdbc:h2:file:${H2_FILE_PATH};MODE=PostgreSQL;AUTO_SERVER=TRUE;DB_CLOSE_DELAY=-1;DATABASE_TO_LOWER=TRUE;CASE_INSENSITIVE_IDENTIFIERS=TRUE
