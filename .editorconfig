root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.java]
indent_size = 2

[*.{js,mjs,cjs,ts,json,yml,yaml,md}]
indent_size = 2

[*.xml]
indent_size = 2

[*.{bat,cmd}]
end_of_line = crlf

[Makefile]
indent_style = tab
